[Unit]
Description=RISC OS Direct VNC session
Wants=network-online.target
After=network-online.target

[Service]
Type=forking
User=ubuntu
Environment=HOME=/home/ubuntu
ExecStart=/usr/local/bin/riscos-direct start-vnc
ExecStop=/usr/local/bin/riscos-direct stop-vnc
RemainAfterExit=yes
TimeoutStartSec=45min

[Install]
WantedBy=multi-user.target
